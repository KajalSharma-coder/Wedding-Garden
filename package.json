{
  "name": "royal-wedding-garden-booking",
  "version": "1.0.0",
  "private": true,
  "engines": {
  "node": "20.x"
},
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev -p 3000",
    "dev:api": "tsx watch server/src/index.ts",
    "dev:all": "npm run dev",
    "build": "next build",
    "start": "next start -p 3000",
    "api:start": "tsx server/src/index.ts",
    "api:build": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit" 
  },
  "dependencies": {
    "@next/third-parties": "^15.0.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.3",
    "concurrently": "^9.1.2",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "next": "^15.1.4",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.22.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
